---
import personalData from '../data/personal.json';
import siteData from '../data/site.json';
import menuData from '../data/menu.json';
import { getSocialLinks } from '../lib/socialLinks';

const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;

const socialLinks = getSocialLinks(personalData as unknown as Record<string, string | string[]>);

const navLinks = menuData.sections.map((s) => ({ label: s.label, href: s.href }));

const { footerAttribution } = siteData;
---

<footer
  id="site-footer"
  style="position: relative; background: var(--footer-bg); border-top: 1px solid var(--footer-border);"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl py-14">
    <div class="footer-grid">
      <div class="footer-left">
        <div class="mt-0">
          <p class="text-lg font-bold gradient-text">{personalData.name}</p>
          <p class="text-slate-500 text-xs mt-1 leading-relaxed max-w-[220px]">
            {siteData.tagline}
          </p>
          <a href={`mailto:${personalData.email}`} class="footer-email mt-3">
            <svg
              class="w-4 h-4 opacity-50 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            {personalData.email}
          </a>
        </div>
      </div>

      <div class="footer-center">
        <nav class="flex flex-col gap-2" aria-label="Footer navigation">
          {
            navLinks.map((link) => (
              <a href={link.href} class="footer-nav-link">
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>

      <div class="footer-right">
        <div class="flex flex-wrap gap-2">
          {siteData.seoKeywords.map((kw) => <span class="footer-kw">{kw}</span>)}
        </div>
      </div>
    </div>
    <div class="footer-divider my-8"></div>

    <div class="flex flex-col items-center gap-4 text-center">
      <p class="text-slate-600 text-sm">
        © {currentYear}
        {personalData.name}
        {
          footerAttribution.builder && (
            <>
              {' '}
              · Built by{' '}
              <a href={footerAttribution.builderUrl} target="_blank">
                {footerAttribution.builder}
              </a>
            </>
          )
        }
        {
          footerAttribution.host && (
            <>
              {' '}
              / Hosting by{' '}
              <a href={footerAttribution.hostUrl} target="_blank">
                {footerAttribution.host}
              </a>
            </>
          )
        }
        &nbsp;·&nbsp;<a href="privacy" class="hover:text-accent transition-colors">Privacy</a
        >&nbsp;·&nbsp;<a href="terms" class="hover:text-accent transition-colors">Terms</a>
      </p>
      <div class="flex items-center gap-5">
        {
          socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social"
              aria-label={link.label}
            >
              <iconify-icon icon={link.icon} width="20" height="20" aria-hidden="true" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .footer-left .gradient-text {
    font-size: 1.5rem;
    font-weight: 800;
  }
</style>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: auto 1fr auto;
      gap: 3rem;
    }
  }

  .footer-left {
    display: flex;
    flex-direction: column;
  }
  .footer-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .footer-right {
    text-align: right;
  }

  @media (max-width: 767px) {
    .footer-center {
      text-align: left;
      align-items: flex-start;
    }
    .footer-right {
      text-align: left;
    }
  }

  .footer-nav-link {
    color: #64748b;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
    position: relative;
    display: inline-block;
  }
  .footer-nav-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, #6366f1, #0ea5e9);
    transition: width 0.3s ease;
  }
  .footer-nav-link:hover {
    color: #a5b4fc;
  }
  .footer-nav-link:hover::after {
    width: 100%;
  }

  .footer-email {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #475569;
    font-size: 0.8rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .footer-email:hover {
    color: #a5b4fc;
  }

  .footer-kw {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #334155;
    background: rgba(99, 102, 241, 0.04);
    border: 1px solid rgba(99, 102, 241, 0.1);
    border-radius: 9999px;
    padding: 0.18rem 0.6rem;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
    cursor: default;
  }
  .footer-kw:hover {
    color: #6366f1;
    border-color: rgba(99, 102, 241, 0.3);
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(99, 102, 241, 0.4) 25%,
      rgba(14, 165, 233, 0.4) 75%,
      transparent 100%
    );
  }

  .footer-social {
    color: #334155;
    display: inline-flex;
    align-items: center;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }
  .footer-social:hover {
    color: #a5b4fc;
    transform: translateY(-2px);
  }
</style>

