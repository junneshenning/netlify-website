---
import siteData from '../data/site.json';

interface ServiceSite {
  badge: string;
  badgeColor: string;
  cardAccent: string;
  glowColor: string;
  iconBg: string;
  iconBorder: string;
  name: string;
  url: string;
  description: string;
  features: string[];
  ctaText: string;
}

const serviceSites = siteData.serviceSites as ServiceSite[];
const [siteA, siteB] = serviceSites;

// SVG path strings for the two service card icons. The badge colour from site.json is
// injected at build time so each card's accent colour is reflected in the icon strokes.
const webIcon = `<rect x="4" y="6" width="40" height="28" rx="3" stroke="currentColor" stroke-width="2.2"/><path d="M16 42h16M24 34v8" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/><path d="M13 20l5 4 8-8" stroke="${siteA?.badgeColor ?? '#6366f1'}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="32" cy="19" r="5" stroke="${siteA?.badgeColor ?? '#6366f1'}" stroke-width="1.8"/><path d="M36 23l3 3" stroke="${siteA?.badgeColor ?? '#6366f1'}" stroke-width="2" stroke-linecap="round"/>`;

const serverIcon = `<rect x="6" y="8"  width="36" height="10" rx="2.5" stroke="currentColor" stroke-width="2.2"/><rect x="6" y="22" width="36" height="10" rx="2.5" stroke="currentColor" stroke-width="2.2"/><rect x="6" y="36" width="36" height="10" rx="2.5" stroke="currentColor" stroke-width="2.2"/><circle cx="38" cy="13" r="2" fill="${siteB?.badgeColor ?? '#10b981'}"/><circle cx="38" cy="27" r="2" fill="${siteB?.badgeColor ?? '#10b981'}"/><circle cx="38" cy="41" r="2" fill="${siteB?.badgeColor ?? '#10b981'}" opacity="0.5"/><rect x="12" y="11" width="14" height="3" rx="1.5" fill="${siteB?.badgeColor ?? '#10b981'}" opacity="0.4"/><rect x="12" y="25" width="10" height="3" rx="1.5" fill="${siteB?.badgeColor ?? '#10b981'}" opacity="0.4"/>`;

// Returns a 16×16 SVG check-circle path string with the given colour applied to the checkmark stroke.
const checkIcon = (color: string) =>
  `<circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`;
---

<section id="services" class="py-24 relative overflow-hidden" style="scroll-margin-top: 80px;">
  <div class="sites-bg" aria-hidden="true">
    <svg
      class="sites-bg-svg"
      viewBox="0 0 800 400"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <circle cx="120" cy="80" r="4" fill="currentColor" opacity="0.15"></circle>
      <circle cx="280" cy="160" r="3" fill="currentColor" opacity="0.12"></circle>
      <circle cx="400" cy="60" r="5" fill="currentColor" opacity="0.18"></circle>
      <circle cx="550" cy="130" r="3" fill="currentColor" opacity="0.12"></circle>
      <circle cx="680" cy="80" r="4" fill="currentColor" opacity="0.15"></circle>
      <circle cx="200" cy="300" r="3" fill="currentColor" opacity="0.1"></circle>
      <circle cx="350" cy="280" r="4" fill="currentColor" opacity="0.13"></circle>
      <circle cx="600" cy="320" r="3" fill="currentColor" opacity="0.1"></circle>
      <circle cx="740" cy="260" r="4" fill="currentColor" opacity="0.13"></circle>
      <line
        x1="120"
        y1="80"
        x2="280"
        y2="160"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="280"
        y1="160"
        x2="400"
        y2="60"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="400"
        y1="60"
        x2="550"
        y2="130"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="550"
        y1="130"
        x2="680"
        y2="80"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="280"
        y1="160"
        x2="350"
        y2="280"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="400"
        y1="60"
        x2="350"
        y2="280"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="550"
        y1="130"
        x2="600"
        y2="320"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="680"
        y1="80"
        x2="740"
        y2="260"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="600"
        y1="320"
        x2="740"
        y2="260"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
      <line
        x1="200"
        y1="300"
        x2="350"
        y2="280"
        stroke="currentColor"
        stroke-width="0.5"
        opacity="0.08"></line>
    </svg>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">Take a Look</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">Projects & Ventures</h2>
      <p class="mt-4 text-base max-w-xl mx-auto" style="color: var(--text-muted);">
        Two sites to visit more of my work.
      </p>
    </div>

    <div class="sites-grid">
      {
        siteA && (
          <div
            class="site-card reveal"
            style={`--card-accent: ${siteA.cardAccent}; transition-delay: 0.05s;`}
          >
            <div class="site-card-glow" style={`--glow-color: ${siteA.glowColor};`} />

            <div
              class="site-icon-wrap"
              style={`--icon-bg: ${siteA.iconBg}; --icon-border: ${siteA.iconBorder};`}
            >
              <svg
                viewBox="0 0 48 48"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="site-svg"
                set:html={webIcon}
              />
            </div>

            <div class="site-content">
              <div class="site-badge" style={`--badge-color: ${siteA.badgeColor};`}>
                {siteA.badge}
              </div>
              <h3 class="site-title">
                <a href={siteA.url} target="_blank" rel="noopener">
                  {siteA.name}
                </a>
              </h3>
              <p class="site-desc">{siteA.description}</p>

              <ul class="site-features">
                {siteA.features.map((f) => (
                  <li>
                    <svg
                      viewBox="0 0 16 16"
                      fill="none"
                      class="site-feature-icon"
                      set:html={checkIcon(siteA.badgeColor)}
                    />
                    {f}
                  </li>
                ))}
              </ul>

              <a
                href={siteA.url}
                target="_blank"
                rel="noopener"
                class="site-cta"
                style={`--cta-color: ${siteA.cardAccent};`}
              >
                {siteA.ctaText}
                <svg viewBox="0 0 20 20" fill="none" class="site-cta-arrow">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.75"
                    d="M3 10h14M10 3l7 7-7 7"
                    stroke="currentColor"
                  />
                </svg>
              </a>
            </div>
          </div>
        )
      }

      <div class="sites-connector" aria-hidden="true">
        <div class="connector-line"></div>
        <div class="connector-pip">
          <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" style="color: var(--text-dimmer);">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"
              stroke="currentColor"></path>
          </svg>
        </div>
        <div class="connector-line"></div>
      </div>

      {
        siteB && (
          <div
            class="site-card reveal"
            style={`--card-accent: ${siteB.cardAccent}; transition-delay: 0.12s;`}
          >
            <div class="site-card-glow" style={`--glow-color: ${siteB.glowColor};`} />

            <div
              class="site-icon-wrap"
              style={`--icon-bg: ${siteB.iconBg}; --icon-border: ${siteB.iconBorder};`}
            >
              <svg
                viewBox="0 0 48 48"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="site-svg"
                set:html={serverIcon}
              />
            </div>

            <div class="site-content">
              <div class="site-badge" style={`--badge-color: ${siteB.badgeColor};`}>
                {siteB.badge}
              </div>
              <h3 class="site-title">
                <a href={siteB.url} target="_blank" rel="noopener">
                  {siteB.name}
                </a>
              </h3>
              <p class="site-desc">{siteB.description}</p>

              <ul class="site-features">
                {siteB.features.map((f) => (
                  <li>
                    <svg
                      viewBox="0 0 16 16"
                      fill="none"
                      class="site-feature-icon"
                      set:html={checkIcon(siteB.badgeColor)}
                    />
                    {f}
                  </li>
                ))}
              </ul>

              <a
                href={siteB.url}
                target="_blank"
                rel="noopener"
                class="site-cta"
                style={`--cta-color: ${siteB.cardAccent};`}
              >
                {siteB.ctaText}
                <svg viewBox="0 0 20 20" fill="none" class="site-cta-arrow">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.75"
                    d="M3 10h14M10 3l7 7-7 7"
                    stroke="currentColor"
                  />
                </svg>
              </a>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .sites-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .sites-bg-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--text);
  }

  .sites-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
    align-items: center;
  }
  @media (min-width: 768px) {
    .sites-grid {
      grid-template-columns: 1fr auto 1fr;
      gap: 0;
    }
  }

  .sites-connector {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 0 1rem;
  }
  @media (min-width: 768px) {
    .sites-connector {
      display: flex;
    }
  }
  .connector-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, var(--border), transparent);
  }
  .connector-pip {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    backdrop-filter: blur(4px);
  }

  .site-card {
    position: relative;
    border-radius: 1.25rem;
    border: 1px solid var(--border);
    background: var(--bg-card);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 2rem;
    overflow: hidden;
    transition:
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .site-card:hover {
    border-color: var(--card-accent, #6366f1);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.2),
      0 0 0 1px color-mix(in srgb, var(--card-accent, #6366f1) 30%, transparent);
    transform: translateY(-4px);
  }

  .site-card-glow {
    position: absolute;
    top: -40%;
    right: -20%;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      var(--glow-color, rgba(99, 102, 241, 0.12)) 0%,
      transparent 70%
    );
    pointer-events: none;
    transition: opacity 0.4s ease;
    opacity: 0.6;
  }
  .site-card:hover .site-card-glow {
    opacity: 1;
  }

  .site-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 0.875rem;
    background: var(--icon-bg, rgba(99, 102, 241, 0.1));
    border: 1px solid var(--icon-border, rgba(99, 102, 241, 0.18));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--text-muted);
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      background 0.3s ease;
  }
  .site-card:hover .site-icon-wrap {
    transform: rotate(-6deg) scale(1.08);
  }
  .site-svg {
    width: 32px;
    height: 32px;
  }

  .site-badge {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--badge-color, #6366f1);
    background: color-mix(in srgb, var(--badge-color, #6366f1) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--badge-color, #6366f1) 25%, transparent);
    border-radius: 9999px;
    padding: 0.2rem 0.6rem;
    margin-bottom: 0.5rem;
  }

  .site-title {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.6rem;
    transition: color 0.25s ease;
  }
  .site-card:hover .site-title {
    color: var(--card-accent, #6366f1);
  }

  .site-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .site-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .site-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-muted);
  }
  .site-feature-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--text-dim);
  }

  .site-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--cta-color, #6366f1);
    text-decoration: none;
    transition:
      gap 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      filter 0.25s ease;
    border-bottom: 1px solid color-mix(in srgb, var(--cta-color, #6366f1) 30%, transparent);
    padding-bottom: 1px;
  }
  .site-cta:hover {
    gap: 0.85rem;
    filter: brightness(1.2);
  }
  .site-cta-arrow {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .site-cta:hover .site-cta-arrow {
    transform: translateX(4px);
  }

  :global([data-theme='light']) .site-card {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }
  :global([data-theme='light']) .site-card:hover {
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.1),
      0 0 0 1px color-mix(in srgb, var(--card-accent, #6366f1) 30%, transparent);
  }
</style>

<script>
  document.querySelectorAll('#services .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(el);
  });
</script>
