---
import '../styles/global.css';
import siteData from '../data/site.json';

interface Props {
  title?: string;
  description?: string;
}

// BASE_URL reflects astro.config.mjs `base` (set via BASE_PATH env var).
// Prepend it to every public/ asset path so the site works when deployed to a sub-directory.
const base = import.meta.env.BASE_URL;
const { title = siteData.title, description = siteData.description } = Astro.props;
---

<!doctype html>
<html lang="en" style="color-scheme: dark;" data-theme-key={siteData.themeStorageKey}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={`${base}images/favicons/favicon.ico`} sizes="any" />
    <link
      rel="apple-touch-icon"
      sizes="57x57"
      href={`${base}images/favicons/apple-icon-57x57.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="60x60"
      href={`${base}images/favicons/apple-icon-60x60.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="72x72"
      href={`${base}images/favicons/apple-icon-72x72.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="76x76"
      href={`${base}images/favicons/apple-icon-76x76.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="114x114"
      href={`${base}images/favicons/apple-icon-114x114.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="120x120"
      href={`${base}images/favicons/apple-icon-120x120.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="144x144"
      href={`${base}images/favicons/apple-icon-144x144.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="152x152"
      href={`${base}images/favicons/apple-icon-152x152.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${base}images/favicons/apple-icon-180x180.png`}
    />
    <link rel="manifest" href={`${base}manifest.json`} />
    <meta name="msapplication-config" content={`${base}browserconfig.xml`} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteData.ogSiteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#020617" id="meta-theme-color" />
    <link href={`${base}fonts/inter.css`} rel="stylesheet" />
    <script is:inline src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" defer
    ></script>
    <title>{title}</title>
    <!-- Runs synchronously before first paint to apply the saved theme without a flash.
         is:inline prevents Astro from bundling or deferring this script. -->
    <script is:inline>
      (function () {
        try {
          var key = document.documentElement.dataset.themeKey || 'portfolio-theme';
          var t = localStorage.getItem(key);
          if (t === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
            var m = document.getElementById('meta-theme-color');
            if (m) m.setAttribute('content', '#f8fafc');
          }
        } catch {}
      })();
    </script>
    <!-- Adds .page-hidden to <body> while the tab is not visible.
         Components can use this class to pause expensive animations. -->
    <script is:inline>
      document.addEventListener('visibilitychange', function () {
        document.body.classList.toggle('page-hidden', document.hidden);
      });
    </script>
    <script is:inline>
      (function () {
        var savedTheme = null;
        window.addEventListener('beforeprint', function () {
          try {
            var key = document.documentElement.dataset.themeKey || 'portfolio-theme';
            savedTheme = localStorage.getItem(key);
          } catch {}
          document.documentElement.removeAttribute('data-theme');
        });
        window.addEventListener('afterprint', function () {
          if (savedTheme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          }
          savedTheme = null;
        });
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>
